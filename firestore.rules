rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['studentId', 'district', 'centre', 'skill']) &&
             data.studentId is string && data.studentId.size() > 0 &&
             data.district is string && data.district.size() > 0 &&
             data.centre is string && data.centre.size() > 0 &&
             data.skill is string && data.skill.size() > 0;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['studentId', 'centre', 'date', 'isPresent']) &&
             data.studentId is string &&
             data.centre is string &&
             data.date is string &&
             data.isPresent is bool;
    }

    function isValidCentre(data) {
      return data.keys().hasAll(['name', 'district']) &&
             data.name is string && data.name.size() > 0 &&
             data.district is string && data.district.size() > 0;
    }

    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidStudent(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidAttendance(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /centres/{centreId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidCentre(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
